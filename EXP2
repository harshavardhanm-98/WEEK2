#include <stdio.h>
int main() {
    float c, f;
    int choice;
    printf("1. Celsius to Fahrenheit\n2. Fahrenheit to Celsius\nEnter choice: ");
    scanf("%d", &choice);
    if(choice == 1) {
        printf("Enter Celsius: ");
        scanf("%f", &c);
        f = (c * 9 / 5) + 32;
        printf("Fahrenheit: %.2f\n", f);
    } else {
   
   printf("Enter Fahrenheit: ");
        scanf("%f", &f);
        c = (f - 32) * 5 / 9;
        printf("Celsius: %.2f\n", c);
    }
    return 0;
}
